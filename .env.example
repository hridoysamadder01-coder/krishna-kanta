# Absolute public URL of the deployed site (no trailing slash).
# Used for canonical URLs, Open Graph metadata, sitemap and structured data.
NEXT_PUBLIC_SITE_URL=https://hridoysamadder01-coder.github.io/krishna-kanta

# Base path when the site is served from a sub-directory (GitHub Pages project site).
# Leave empty when deploying to a root domain (Vercel, Cloudflare, VPS).
NEXT_PUBLIC_BASE_PATH=/krishna-kanta

# Optional endpoint that receives contact-form submissions as JSON (POST).
# When empty, the form shows an explicit "channel not yet open" state and
# never pretends a message was sent. See DEPLOYMENT.md.
NEXT_PUBLIC_CONTACT_ENDPOINT=

# Official press/media contact e-mail. When empty the press page shows
# "Official media contact information will be published after verification."
NEXT_PUBLIC_PRESS_EMAIL=
